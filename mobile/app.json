{
  "expo": {
    "name": "Weather App",
    "slug": "weather",
    "version": "1.2",
    "orientation": "portrait",
    "icon": "./assets/weatherIcon2.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mgstop13.weather"
    },
    "android": {
      "package": "com.mgstop13.weather",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/weatherIcon2.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
