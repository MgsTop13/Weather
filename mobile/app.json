{
  "expo": {
    "name": "Weather App",
    "slug": "weather",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/weatherIcon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mgstop13.weather"
    },
    "android": {
      "package": "com.mgstop13.weather",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#2e2e2e",
        "foregroundImage": "./assets/weatherIcon.png"
      }
    },
    "web": {
      "favicon": "./assets/weatherIcon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
